{
    "name": "tugrul/mvc-core-starter",
    "description": "PHP 8.5 MVC starter for shared hosting deployments",
    "type": "project",
    "require": {
        "php": "^8.5",
        "dompdf/dompdf": "^3.1",
        "guzzlehttp/guzzle": "^7.10",
        "intervention/image": "^3.11",
        "minishlink/web-push": "^10.0",
        "monolog/monolog": "^3.9",
        "nikic/fast-route": "^1.3",
        "php-di/php-di": "^7.0",
        "phpoffice/phpspreadsheet": "^2.2",
        "ramsey/uuid": "^4.7",
        "symfony/mailer": "^8.0",
        "twilio/sdk": "^8.11",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "friendsofphp/php-cs-fixer": "^3.79",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src",
        "fix": "php-cs-fixer fix src --allow-risky=yes",
        "migrate": "php scripts/migrate.php",
        "seed": "php scripts/seed.php",
        "migrate-seed": "php scripts/migrate-seed.php",
        "cron": "php scripts/cron-runner.php",
        "build-assets": "npm run build",
        "generate-vapid": "php scripts/generate-vapid.php"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.5.0"
        }
    }
}
