{
  "name": "mvc-core-starter",
  "private": true,
  "version": "1.0.0",
  "description": "Optional frontend tooling for MVC core starter",
  "scripts": {
    "build:css": "tailwindcss -i ./resources/css/app.css -o ./public/assets/app.css --minify",
    "dev:css": "tailwindcss -i ./resources/css/app.css -o ./public/assets/app.css --watch",
    "build:js": "esbuild ./resources/js/app.js --bundle --minify --outfile=./public/assets/app.js",
    "dev:js": "esbuild ./resources/js/app.js --bundle --outfile=./public/assets/app.js --watch",
    "build": "npm run build:css && npm run build:js",
    "dev": "npm-run-all --parallel dev:css dev:js"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.11",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
