APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=change-this-key
APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_ENABLED_LOCALES=tr,en

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mvc_core
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

SESSION_SECURE_COOKIE=false
UPLOAD_MAX_SIZE_MB=5
AUTO_MIGRATE_ON_BOOT=false
MAIL_DSN=smtp://localhost
MAIL_FROM=no-reply@example.com
CRON_ENABLED=true
